{
  "$schema": "https://json.schemastore.org/web-manifest-combined.json",
  "name": "Denúncias Urbanas",
  "short_name": "Denúncias",
  "description": "Registre e acompanhe problemas urbanos na sua cidade.",
  "start_url": "/",
  "scope": "/",
  "display": "standalone",
  "orientation": "portrait-primary",
  "theme_color": "#2563EB",
  "background_color": "#F8F9FA",
  "lang": "pt-BR",
  "icons": [
    {
      "src": "/icons/icon-192.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "/icons/icon-512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "/icons/icon-maskable-512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "maskable"
    }
  ],
  "categories": ["utilities", "lifestyle"],
  "screenshots": [],
  "shortcuts": [
    {
      "name": "Nova Denúncia",
      "short_name": "Nova",
      "description": "Registre um novo problema urbano",
      "url": "/?action=new-report",
      "icons": [{ "src": "/icons/icon-192.png", "sizes": "192x192" }]
    },
    {
      "name": "Minhas Denúncias",
      "short_name": "Minhas",
      "description": "Ver minhas denúncias",
      "url": "/?screen=my-reports",
      "icons": [{ "src": "/icons/icon-192.png", "sizes": "192x192" }]
    }
  ]
}
