# ── Banco de Dados ──────────────────────────────────────────────────────────
DB_NAME=denuncias_urbanas
DB_USER=postgres
DB_PASSWORD=postgres
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/denuncias_urbanas

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Auth ─────────────────────────────────────────────────────────────────────
JWT_SECRET=troque_por_um_segredo_forte_em_producao

# ── Web Push (VAPID) ─────────────────────────────────────────────────────────
# Gere com: cd backend && npx ts-node src/scripts/generate-vapid.ts
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=mailto:admin@denunciasurbanas.com

# ── Frontend (variáveis expostas ao Vite) ────────────────────────────────────
VITE_API_URL=http://localhost:80
VITE_VAPID_PUBLIC_KEY=
