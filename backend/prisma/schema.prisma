generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Enums ─────────────────────────────────────────────────────────────────────

enum Role {
  cidadao
  admin
}

enum StatusDenuncia {
  aberto
  analise
  resolvido
  cancelado
}

enum CategoriaDenuncia {
  buraco
  iluminacao
  lixo
  calcada
  vandalismo
  outros
}

// ── Models ────────────────────────────────────────────────────────────────────

model Usuario {
  id                String             @id @default(cuid())
  clerkId           String             @unique @map("clerk_id")
  nome              String
  email             String             @unique
  role              Role               @default(cidadao)
  criadoEm         DateTime           @default(now()) @map("criado_em")
  atualizadoEm     DateTime           @updatedAt      @map("atualizado_em")

  denuncias         Denuncia[]
  pushSubscriptions PushSubscription[]

  @@map("usuarios")
}

model PushSubscription {
  id        String   @id @default(cuid())
  usuarioId String   @map("usuario_id")
  endpoint  String   @unique
  p256dh    String
  auth      String
  criadoEm DateTime @default(now()) @map("criado_em")

  usuario   Usuario  @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@map("push_subscriptions")
}

model Denuncia {
  id           String            @id @default(cuid())
  titulo       String
  descricao    String
  categoria    CategoriaDenuncia
  endereco     String
  imagemUrl    String?           @map("imagem_url")
  imagemBytes  Bytes?            @map("imagem_bytes")
  imagemMime   String?           @map("imagem_mime")
  status       StatusDenuncia    @default(aberto)
  lat          Float?
  lng          Float?
  autorId      String            @map("autor_id")
  autor        Usuario           @relation(fields: [autorId], references: [id])
  criadoEm    DateTime          @default(now()) @map("criado_em")
  atualizadoEm DateTime         @updatedAt      @map("atualizado_em")

  @@map("denuncias")
}
