generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Enums ─────────────────────────────────────────────────────────────────────

enum Role {
  cidadao
  admin
}

enum StatusDenuncia {
  aberto
  analise
  resolvido
  cancelado
}

enum CategoriaDenuncia {
  buraco
  iluminacao
  lixo
  calcada
  vandalismo
  outros
}

// ── Models ────────────────────────────────────────────────────────────────────

model Usuario {
  id            String             @id @default(cuid())
  nome          String
  email         String             @unique
  senha         String
  primeiroLogin Boolean            @default(true) @map("primeiro_login")
  role          Role               @default(admin)
  criadoEm     DateTime           @default(now()) @map("criado_em")
  atualizadoEm DateTime           @updatedAt      @map("atualizado_em")

  denuncias              Denuncia[]
  pushSubscriptions      PushSubscription[]

  @@map("usuarios")
}

model PushSubscription {
  id        String   @id @default(cuid())
  usuarioId String?  @map("usuario_id")
  endpoint  String   @unique
  p256dh    String
  auth      String
  criadoEm DateTime @default(now()) @map("criado_em")

  usuario   Usuario? @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  denuncias PushSubscriptionDenuncia[]

  @@map("push_subscriptions")
}

model PushSubscriptionDenuncia {
  subscriptionId String @map("subscription_id")
  denunciaId     String @map("denuncia_id")

  subscription PushSubscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  denuncia     Denuncia         @relation(fields: [denunciaId], references: [id], onDelete: Cascade)

  @@id([subscriptionId, denunciaId])
  @@map("push_subscription_denuncias")
}

model Denuncia {
  id           String            @id @default(cuid())
  titulo       String
  descricao    String
  categoria    CategoriaDenuncia
  endereco     String
  imagemUrl    String?           @map("imagem_url")
  imagemBytes  Bytes?            @map("imagem_bytes")
  imagemMime   String?           @map("imagem_mime")
  status       StatusDenuncia    @default(aberto)
  lat          Float?
  lng          Float?
  autorId      String?           @map("autor_id")
  autor        Usuario?          @relation(fields: [autorId], references: [id])
  criadoEm    DateTime          @default(now()) @map("criado_em")
  atualizadoEm DateTime         @updatedAt      @map("atualizado_em")

  pushSubscriptions PushSubscriptionDenuncia[]

  @@map("denuncias")
}
